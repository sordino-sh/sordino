/target
# e2e runtime artifacts (proxy/fake logs, captured bodies, session state)
e2e/state/
e2e/state-*/
*.log
# per-developer local-scope privacy overrides (`/privacy … --scope local`)
zlauder.local.toml
**/zlauder.local.toml

# pair/agent worktrees (harness artifacts; symlinks point outside the repo)
.claude/worktrees/

# local co-development override (path deps); keep the .example tracked
.cargo/config.toml

# release CI staging (assembled into the plugin-dist branch / GitHub Release)
/out/
/pkg/
/stage/
# prebuilt plugin binaries are shipped on the plugin-dist branch, never on main;
# a locally-dropped bin/ (for testing the resolver) stays untracked
zlauder-plugin/bin/
