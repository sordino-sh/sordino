{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:18820",
    "SORDINO_PORT": "18820",
    "SORDINO_STATE_DIR": "/home/failspy/Projects/sordino/e2e/state"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/failspy/Projects/sordino/target/debug/sordino-hooks session-start --proxy-bin /home/failspy/Projects/sordino/target/debug/sordino-proxy --config /home/failspy/Projects/sordino/e2e/sordino.toml"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/failspy/Projects/sordino/target/debug/sordino-hooks statusline"
  }
}
